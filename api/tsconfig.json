{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": ".vercel/output",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["."]
}
